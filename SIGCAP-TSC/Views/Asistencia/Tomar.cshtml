@model SIGCAP_TSC.Models.Asistencia.TomarAsistenciaFormViewModel
@{
    ViewData["Title"] = "Tomar Asistencia";
    var evento = ViewBag.Evento as SIGCAP_TSC.Models.Eventos.EventoViewModel;
}

<div class="max-w-4xl mx-auto space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <a href="@Url.Action("Index", "Asistencia", new { id = Model.id_evento })" class="p-1.5 text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors tooltip" title="Volver al Evento">
                    <i data-lucide="arrow-left" class="h-5 w-5"></i>
                </a>
                <h1 class="text-2xl font-bold text-gray-900">Tomar Asistencia</h1>
            </div>
            <p class="text-gray-500 text-sm ml-10 flex items-center gap-2">
                <span class="font-medium text-gray-700">@evento?.nombre_evento</span>
                <i data-lucide="chevron-right" class="h-3 w-3 text-gray-300"></i>
                <span class="font-medium text-indigo-700">Sesión: @Model.nombre_sesion</span>
                <span class="text-gray-400 text-xs">(@Model.fecha_sesion.ToShortDateString())</span>
            </p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ViewBag.Error))
    {
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl flex items-start gap-3 shadow-sm">
            <i data-lucide="alert-circle" class="h-5 w-5 text-red-500 shrink-0 mt-0.5"></i>
            <div class="text-sm">
                <p class="font-semibold mb-1">Error al guardar la asistencia</p>
                <p>@ViewBag.Error</p>
            </div>
        </div>
    }

    <!-- Panel de Formulario -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        
        <form asp-action="SaveBulk" method="post" id="asistenciaForm">
            <!-- Hidden Fields -->
            <input type="hidden" asp-for="id_sesion" />
            <input type="hidden" asp-for="id_evento" />
            
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left">
                    <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b border-gray-100">
                        <tr>
                            <th class="px-4 py-3 font-medium w-64">Participante</th>
                            <th class="px-4 py-3 font-medium w-auto">Estado de Asistencia</th>
                            <th class="px-4 py-3 font-medium w-64">Observación (Opcional)</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        @if (Model.Participantes == null || !Model.Participantes.Any())
                        {
                            <tr>
                                <td colspan="3" class="px-4 py-8 text-center text-gray-500">
                                    <i data-lucide="users" class="h-8 w-8 mx-auto text-gray-300 mb-2"></i>
                                    No hay participantes para evaluar en esta sesión.
                                </td>
                            </tr>
                        }
                        else
                        {
                            for (int i = 0; i < Model.Participantes.Count; i++)
                            {
                                <tr class="hover:bg-gray-50/50 transition-colors group">
                                    <td class="px-4 py-4 align-top">
                                        <!-- Ocultos del participante -->
                                        <input type="hidden" asp-for="Participantes[i].id_inscripcion" />
                                        <input type="hidden" asp-for="Participantes[i].id_asistencia" />
                                        
                                        <div class="font-medium text-gray-900 group-hover:text-indigo-700 transition-colors">
                                            @Model.Participantes[i].nombre_participante
                                        </div>
                                        <div class="text-xs text-gray-500 mt-0.5">
                                            @Model.Participantes[i].identificacion
                                        </div>
                                    </td>
                                    <td class="px-4 py-4 align-top">
                                        <div class="flex flex-wrap gap-2">
                                            @foreach (var estado in Model.EstadosAsistencia)
                                            {
                                                var uniqueId = $"estado_{i}_{estado.id_estado_asistencia}";
                                                bool isChecked = Model.Participantes[i].id_estado_asistencia == estado.id_estado_asistencia;
                                                
                                                // Asignar colores por defecto basado en códigos usuales (P, A, T, J)
                                                string colorCls = estado.codigo switch
                                                {
                                                    "P" => "peer-checked:bg-emerald-50 peer-checked:border-emerald-500 peer-checked:text-emerald-700 hover:border-emerald-200",
                                                    "A" => "peer-checked:bg-red-50 peer-checked:border-red-500 peer-checked:text-red-700 hover:border-red-200",
                                                    "T" => "peer-checked:bg-amber-50 peer-checked:border-amber-500 peer-checked:text-amber-700 hover:border-amber-200",
                                                    "J" => "peer-checked:bg-blue-50 peer-checked:border-blue-500 peer-checked:text-blue-700 hover:border-blue-200",
                                                    _ => "peer-checked:bg-indigo-50 peer-checked:border-indigo-500 peer-checked:text-indigo-700 hover:border-indigo-200"
                                                };

                                                <label for="@uniqueId" class="relative cursor-pointer transition-all">
                                                    <input type="radio" 
                                                           id="@uniqueId" 
                                                           name="Participantes[@i].id_estado_asistencia" 
                                                           value="@estado.id_estado_asistencia" 
                                                           class="peer sr-only"
                                                           @(isChecked ? "checked" : "") />
                                                    <div class="px-3 py-1.5 text-xs font-medium rounded-lg border border-gray-200 text-gray-600 bg-white transition-all select-none @colorCls">
                                                        @estado.nombre
                                                    </div>
                                                </label>
                                            }
                                        </div>
                                    </td>
                                    <td class="px-4 py-4 align-top">
                                        <input type="text" asp-for="Participantes[i].observacion" 
                                               class="w-full text-xs rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 placeholder-gray-400" 
                                               placeholder="Notas..." />
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="p-4 bg-gray-50 border-t border-gray-100 flex justify-end gap-3">
                <a href="@Url.Action("Index", "Asistencia", new { id = Model.id_evento })" 
                   class="px-4 py-2 border border-gray-300 text-gray-700 bg-white rounded-lg hover:bg-gray-50 transition shadow-sm text-sm font-medium">
                    Cancelar
                </a>
                <button type="submit" 
                        class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition shadow-sm text-sm font-medium flex items-center gap-2">
                    <i data-lucide="save" class="h-4 w-4"></i>
                    Guardar Asistencia
                </button>
            </div>
        </form>
    </div>
</div>
