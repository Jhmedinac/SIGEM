@model IEnumerable<SIGCAP_TSC.Models.Asistencia.ResumenParticipanteViewModel>
@{
    ViewData["Title"] = "Asistencia del Evento";
    var evento = ViewBag.Evento as SIGCAP_TSC.Models.Eventos.EventoViewModel;
    var sesiones = ViewBag.Sesiones as List<SIGCAP_TSC.Models.Asistencia.SesionAsistenciaViewModel>;
}

<div class="space-y-6">
    <!-- Header principal -->
    <div class="flex items-center justify-between">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <a href="@Url.Action("Index", "Eventos")" class="p-1.5 text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors">
                    <i data-lucide="arrow-left" class="h-5 w-5"></i>
                </a>
                <h1 class="text-2xl font-bold text-gray-900">Asistencia y Participantes</h1>
            </div>
            <p class="text-gray-500 text-sm ml-10">
                <span class="font-medium text-gray-700">@evento?.nombre_evento</span>
                <span class="mx-2 text-gray-300">|</span>
                <span class="font-mono text-xs uppercase bg-gray-100 px-2 py-0.5 rounded text-gray-600">@evento?.codigo_evento</span>
            </p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-50 text-green-700 p-4 border border-green-200 rounded-lg flex items-center gap-3">
            <i data-lucide="check-circle" class="h-5 w-5 text-green-500"></i>
            <span class="text-sm font-medium">@TempData["SuccessMessage"]</span>
        </div>
    }
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 text-red-700 p-4 border border-red-200 rounded-lg flex items-center gap-3">
            <i data-lucide="alert-circle" class="h-5 w-5 text-red-500"></i>
            <span class="text-sm font-medium">@TempData["ErrorMessage"]</span>
        </div>
    }

    <!-- Grilla de 2 columnas: Sesiones vs Participantes -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Columna Izquierda: Sesiones -->
        <div class="lg:col-span-1 space-y-4">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-4 border-b border-gray-100 flex items-center justify-between bg-gray-50">
                    <h2 class="font-semibold text-gray-800 flex items-center gap-2">
                        <i data-lucide="calendar" class="h-4 w-4 text-indigo-500"></i>
                        Sesiones del Evento
                    </h2>
                    <span class="text-xs font-medium bg-indigo-100 text-indigo-700 px-2 py-1 rounded-full">
                        @(sesiones?.Count ?? 0) Sesiones
                    </span>
                </div>
                
                <div class="p-0">
                    @if (sesiones == null || !sesiones.Any())
                    {
                        <div class="p-6 text-center text-sm text-gray-500">
                            <i data-lucide="calendar-x" class="h-8 w-8 mx-auto text-gray-300 mb-2"></i>
                            <p class="mb-4">No hay sesiones programadas para este evento.</p>
                            <form asp-action="GenerarSesiones" asp-controller="Asistencia" method="post">
                                <input type="hidden" name="idEvento" value="@evento?.id_evento" />
                                <button type="submit" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded-lg transition-colors">
                                    <i data-lucide="wand-2" class="h-4 w-4"></i>
                                    Generar Sesiones Diarias
                                </button>
                            </form>
                            <p class="text-xs text-gray-400 mt-2 text-balance">
                                Se crearán sesiones automáticamente (lunes a viernes) entre el @(evento?.fecha_inicio?.ToShortDateString() ?? "inicio") y el @(evento?.fecha_fin?.ToShortDateString() ?? "fin")
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="divide-y divide-gray-100">
                            @foreach (var s in sesiones)
                            {
                                <div class="p-4 hover:bg-gray-50 transition-colors group">
                                    <div class="flex justify-between items-start mb-2">
                                        <div>
                                            <h3 class="text-sm font-medium text-gray-900 leading-tight">@s.nombre_sesion</h3>
                                            <p class="text-xs text-gray-500 mt-0.5">@s.fecha_sesion.ToShortDateString() • @s.hora_inicio - @s.hora_fin</p>
                                        </div>
                                    </div>
                                    <div class="flex justify-between items-center mt-3 pt-3 border-t border-gray-50">
                                        <span class="text-xs text-gray-500 flex items-center gap-1.5 tooltip-container">
                                            <i data-lucide="users" class="h-3.5 w-3.5 text-gray-400"></i>
                                            @s.registros_asistencia registros
                                        </span>
                                        <a href="@Url.Action("Tomar", new { idSesion = s.id_sesion, idEvento = s.id_evento })" 
                                           class="text-xs font-medium text-indigo-600 bg-indigo-50 hover:bg-indigo-600 hover:text-white px-3 py-1.5 rounded-lg transition-colors flex items-center gap-1">
                                            <i data-lucide="check-square" class="h-3.5 w-3.5"></i>
                                            Tomar Asistencia
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Columna Derecha: Participantes Inscritos -->
        <div class="lg:col-span-2 space-y-4">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-4 border-b border-gray-100 flex items-center justify-between bg-gray-50">
                    <h2 class="font-semibold text-gray-800 flex items-center gap-2">
                        <i data-lucide="users" class="h-4 w-4 text-indigo-500"></i>
                        Participantes Inscritos y Resumen
                    </h2>
                    <span class="text-xs font-medium bg-emerald-100 text-emerald-700 px-2 py-1 rounded-full">
                        @(Model?.Count() ?? 0) Inscritos
                    </span>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left">
                        <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b border-gray-100">
                            <tr>
                                <th class="px-4 py-3 font-medium">Participante</th>
                                <th class="px-4 py-3 font-medium text-center" title="Presentes">P</th>
                                <th class="px-4 py-3 font-medium text-center" title="Ausentes">A</th>
                                <th class="px-4 py-3 font-medium text-center" title="Tardanzas">T</th>
                                <th class="px-4 py-3 font-medium text-center" title="Justificados">J</th>
                                <th class="px-4 py-3 font-medium text-right">% Asist.</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50">
                            @if (Model == null || !Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="px-4 py-8 text-center text-gray-500">
                                        <i data-lucide="user-x" class="h-8 w-8 mx-auto text-gray-300 mb-2"></i>
                                        No hay participantes inscritos en este evento.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var p in Model)
                                {
                                    string pctColor = p.porcentaje_asistencia >= 80 ? "text-emerald-600 bg-emerald-50" :
                                                      (p.porcentaje_asistencia >= 60 ? "text-amber-600 bg-amber-50" : "text-red-600 bg-red-50");

                                    <tr class="hover:bg-gray-50/50 transition-colors">
                                        <td class="px-4 py-3">
                                            <div class="font-medium text-gray-900">@p.nombre_participante</div>
                                            <div class="text-xs text-gray-500">@p.identificacion</div>
                                        </td>
                                        <td class="px-4 py-3 text-center">
                                            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full @(p.presentes > 0 ? "bg-emerald-100 text-emerald-700 font-semibold text-xs" : "text-gray-300 text-xs")">
                                                @p.presentes
                                            </span>
                                        </td>
                                        <td class="px-4 py-3 text-center">
                                            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full @(p.ausentes > 0 ? "bg-red-100 text-red-700 font-semibold text-xs" : "text-gray-300 text-xs")">
                                                @p.ausentes
                                            </span>
                                        </td>
                                        <td class="px-4 py-3 text-center">
                                            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full @(p.tardanzas > 0 ? "bg-amber-100 text-amber-700 font-semibold text-xs" : "text-gray-300 text-xs")">
                                                @p.tardanzas
                                            </span>
                                        </td>
                                        <td class="px-4 py-3 text-center">
                                            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full @(p.justificados > 0 ? "bg-blue-100 text-blue-700 font-semibold text-xs" : "text-gray-300 text-xs")">
                                                @p.justificados
                                            </span>
                                        </td>
                                        <td class="px-4 py-3 text-right">
                                            <span class="px-2 py-1 rounded font-semibold text-xs @pctColor">
                                                @p.porcentaje_asistencia%
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
    </div>
</div>
