@model SIGCAP_TSC.Models.Profile.ChangePasswordViewModel
@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="max-w-2xl mx-auto space-y-6">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-6 border-b border-gray-100 bg-gray-50 flex items-center gap-4">
            <div class="h-16 w-16 rounded-full bg-indigo-600 text-white flex items-center justify-center font-bold text-2xl shadow-md ring-4 ring-indigo-50">
                A
            </div>
            <div>
                <h2 class="text-xl font-bold text-gray-900">Configuración de Usuario</h2>
                <p class="text-sm text-gray-500 mt-1">Administra tu información de seguridad personal.</p>
            </div>
        </div>

        <div class="p-6">
            <div class="mb-6">
                <h3 class="text-lg font-semibold text-gray-800 border-b border-gray-100 pb-2 mb-4">Cambio de Contraseña</h3>
                
                @if (TempData["Success"] != null)
                {
                    <div class="mb-4 p-4 rounded-xl bg-green-50 border border-green-100 flex gap-3 text-green-800">
                        <i data-lucide="check-circle" class="h-5 w-5 shrink-0"></i>
                        <p class="text-sm font-medium">@TempData["Success"]</p>
                    </div>
                }

                @if (ViewBag.Error != null)
                {
                    <div class="mb-4 p-4 rounded-xl bg-amber-50 border border-amber-100 flex gap-3 text-amber-800">
                        <i data-lucide="alert-triangle" class="h-5 w-5 shrink-0"></i>
                        <p class="text-sm font-medium">@ViewBag.Error</p>
                    </div>
                }

                <form asp-action="ChangePassword" method="post" class="space-y-4">
                    <div>
                        <label asp-for="Actual" class="block text-sm font-medium text-gray-700 mb-1">Contraseña Actual</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i data-lucide="lock" class="h-5 w-5 text-gray-400"></i>
                            </div>
                            <input asp-for="Actual" type="password" required class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 outline-none transition-all text-sm" />
                        </div>
                    </div>

                    <div>
                        <label asp-for="Nueva" class="block text-sm font-medium text-gray-700 mb-1">Nueva Contraseña</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i data-lucide="key" class="h-5 w-5 text-gray-400"></i>
                            </div>
                            <input asp-for="Nueva" type="password" required minlength="6" class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 outline-none transition-all text-sm" />
                        </div>
                    </div>

                    <div>
                        <label asp-for="Confirmar" class="block text-sm font-medium text-gray-700 mb-1">Confirmar Nueva Contraseña</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i data-lucide="key" class="h-5 w-5 text-gray-400"></i>
                            </div>
                            <input asp-for="Confirmar" type="password" required minlength="6" class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 outline-none transition-all text-sm" />
                        </div>
                    </div>

                    <div class="pt-4 flex justify-end">
                        <button type="submit" class="px-5 py-2.5 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition shadow-sm flex items-center gap-2">
                            <i data-lucide="save" class="h-4 w-4"></i> Actualizar Contraseña
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
