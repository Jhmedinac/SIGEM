@model IEnumerable<SIGCAP_TSC.Models.Eventos.EventoViewModel>
@{
    ViewData["Title"] = "Repositorio Histórico";
    
    var tipos = ViewBag.Tipos as List<SIGCAP_TSC.Models.Eventos.CatalogoBasicoViewModel>;
    var modalidades = ViewBag.Modalidades as List<SIGCAP_TSC.Models.Eventos.CatalogoBasicoViewModel>;
    var estados = ViewBag.Estados as List<SIGCAP_TSC.Models.Eventos.CatalogoBasicoViewModel>;
    var salones = ViewBag.Salones as List<SIGCAP_TSC.Models.Eventos.SalonBasicoViewModel>;
    var facilitadores = ViewBag.Facilitadores as List<SIGCAP_TSC.Models.Eventos.FacilitadorBasicoViewModel>;

    string GetNombreEstado(int? id) => estados?.FirstOrDefault(e => e.Id == id)?.Nombre ?? "DESCONOCIDO";
    string GetNombreTipo(int? id) => tipos?.FirstOrDefault(t => t.Id == id)?.Nombre ?? "-";
    string GetNombreModalidad(int? id) => modalidades?.FirstOrDefault(m => m.Id == id)?.Nombre ?? "-";
    string GetNombreSalon(int? id) => salones?.FirstOrDefault(s => s.id_salon == id)?.DisplayName ?? "-";
    string GetNombreFacilitador(int? id) => facilitadores?.FirstOrDefault(f => f.id_facilitador == id)?.DisplayName ?? "-";
    
    string GetEstiloEstado(int? id)
    {
        return id switch
        {
            4 => "bg-indigo-100 text-indigo-700",
            5 => "bg-red-100 text-red-600",
            _ => "bg-gray-100 text-gray-600"
        };
    }
}

<div class="space-y-5">
    <!-- Header -->
    <div class="flex justify-between items-center flex-wrap gap-3">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
                <i data-lucide="archive" class="h-7 w-7 text-indigo-600"></i>
                Repositorio Histórico
            </h1>
            <p class="text-gray-500 text-sm mt-1">Cursos y eventos finalizados o cancelados - Solo consulta</p>
        </div>
    </div>

    <!-- Info Banner -->
    <div class="flex items-center gap-3 bg-amber-50 text-amber-800 px-4 py-3 rounded-lg border border-amber-200 text-sm">
        <i data-lucide="info" class="h-5 w-5 flex-shrink-0 text-amber-500"></i>
        <span>Los eventos en este repositorio son de <strong>solo consulta</strong>. No se pueden editar, eliminar ni inscribir nuevos participantes.</span>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-16 bg-gray-50 rounded-xl border border-dashed border-gray-200 mt-6">
            <i data-lucide="archive" class="mx-auto h-12 w-12 text-gray-300 mb-3"></i>
            <h3 class="text-sm font-semibold text-gray-700">No hay eventos en el histórico</h3>
            <p class="text-sm text-gray-400 mt-1">Los eventos finalizados o cancelados aparecerán aquí.</p>
        </div>
    }
    else
    {
        <!-- Cards grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mt-2">
            @foreach (var evt in Model)
            {
                int cupoMaximo = evt.cupo_maximo > 0 ? evt.cupo_maximo : 1;
                int cupoActual = evt.cupo_actual ?? 0;
                float pct = ((float)cupoActual / cupoMaximo) * 100;

                <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition group flex flex-col relative opacity-90">
                    <div class="flex justify-between items-start mb-3">
                        <span class="px-2.5 py-1 rounded-full text-xs font-semibold @GetEstiloEstado(evt.id_estado)">
                            @GetNombreEstado(evt.id_estado)
                        </span>
                        
                        <div class="flex gap-1 items-center">
                            <a href="@Url.Action("HistoricoDetalle", new { id = evt.id_evento })" class="p-1.5 text-gray-400 hover:text-indigo-600 rounded-lg hover:bg-indigo-50 transition" title="Ver Detalle">
                                <i data-lucide="eye" class="h-4 w-4"></i>
                            </a>
                            <a href="@Url.Action("Participantes", new { id = evt.id_evento })" class="p-1.5 text-gray-400 hover:text-emerald-600 rounded-lg hover:bg-emerald-50 transition" title="Ver Participantes">
                                <i data-lucide="clipboard-list" class="h-4 w-4"></i>
                            </a>
                        </div>
                    </div>

                    <h3 class="text-base font-bold text-gray-900 mb-0.5 leading-tight">@evt.nombre_evento</h3>
                    <p class="text-xs text-gray-400 font-mono uppercase tracking-wider mb-4">@evt.codigo_evento</p>

                    <div class="space-y-2 text-sm text-gray-600 flex-1">
                        <div class="flex items-center gap-2">
                            <i data-lucide="calendar" class="h-4 w-4 text-indigo-400 flex-shrink-0"></i>
                            <span>@(evt.fecha_inicio.HasValue ? evt.fecha_inicio.Value.ToShortDateString() : "") &rarr; @(evt.fecha_fin.HasValue ? evt.fecha_fin.Value.ToShortDateString() : "")</span>
                        </div>
                        @if (evt.id_facilitador.HasValue)
                        {
                            <div class="flex items-center gap-2">
                                <i data-lucide="user" class="h-4 w-4 text-indigo-400 flex-shrink-0"></i>
                                <span class="truncate font-medium text-indigo-700">@GetNombreFacilitador(evt.id_facilitador)</span>
                            </div>
                        }
                        
                        <div class="flex items-center gap-2">
                            <i data-lucide="users" class="h-4 w-4 text-indigo-400 flex-shrink-0"></i>
                            <div class="flex-1">
                                <div class="flex justify-between text-xs mb-1">
                                    <span>Inscritos: <strong>@cupoActual/@evt.cupo_maximo</strong></span>
                                    <span class="text-gray-400">@(Math.Round(pct))%</span>
                                </div>
                                <div class="h-1.5 bg-gray-100 rounded-full">
                                    <div class="h-1.5 rounded-full bg-indigo-300" style="width: @pct%"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-t border-gray-50 flex justify-between items-center">
                        <span class="text-xs text-gray-400 bg-gray-50 px-2 py-1 rounded flex items-center gap-1">
                            <i data-lucide="monitor" class="h-3 w-3"></i>
                            @GetNombreModalidad(evt.id_modalidad)
                        </span>
                        <span class="text-[10px] font-bold uppercase tracking-wider bg-indigo-50 text-indigo-600 px-2 py-1 rounded">
                            @GetNombreTipo(evt.id_tipo_evento)
                        </span>
                    </div>
                </div>
            }
        </div>
    }
</div>
