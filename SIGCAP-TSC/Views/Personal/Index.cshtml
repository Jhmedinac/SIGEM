@model List<SIGCAP_TSC.Models.Personal.PersonalViewModel>
@{
    ViewData["Title"] = "Gestión de Personal";
}

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
        <p class="text-sm text-gray-500 mt-1">Administra los usuarios administrativos y empleados del sistema</p>
    </div>
    <a href="@Url.Action("Form", "Personal")" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl text-sm font-semibold transition-all shadow-sm shadow-indigo-200">
        <i data-lucide="user-plus" class="h-4 w-4"></i>
        Nuevo Personal
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="mb-6 p-4 rounded-xl bg-green-50 border border-green-100 flex gap-3 text-green-800">
        <i data-lucide="check-circle" class="h-5 w-5 shrink-0"></i>
        <p class="text-sm">@TempData["Success"]</p>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-100 flex gap-3 text-red-800">
        <i data-lucide="alert-circle" class="h-5 w-5 shrink-0"></i>
        <p class="text-sm">@TempData["Error"]</p>
    </div>
}

<div class="bg-white rounded-2xl shadow-sm ring-1 ring-gray-900/5 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100">
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Identificación</th>
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Nombres Completos</th>
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Contacto</th>
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-right">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors group">
                            <td class="px-6 py-4">
                                <span class="text-sm font-semibold text-gray-900">@item.identificacion</span>
                            </td>
                            <td class="px-6 py-4">
                                <p class="text-sm font-semibold text-gray-900">@item.nombres @item.apellidos</p>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex flex-col gap-1">
                                    @if (!string.IsNullOrEmpty(item.email))
                                    {
                                        <span class="inline-flex items-center gap-1.5 text-xs text-gray-600">
                                            <i data-lucide="mail" class="h-3.5 w-3.5 text-gray-400"></i>
                                            @item.email
                                        </span>
                                    }
                                    @if (!string.IsNullOrEmpty(item.telefono))
                                    {
                                        <span class="inline-flex items-center gap-1.5 text-xs text-gray-600">
                                            <i data-lucide="phone" class="h-3.5 w-3.5 text-gray-400"></i>
                                            @item.telefono
                                        </span>
                                    }
                                    @if (string.IsNullOrEmpty(item.email) && string.IsNullOrEmpty(item.telefono))
                                    {
                                        <span class="text-xs text-gray-400 italic">Sin contacto</span>
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <a href="@Url.Action("Form", "Personal", new { id = item.id_personal })" class="p-2 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors" title="Editar">
                                        <i data-lucide="edit-2" class="h-4 w-4"></i>
                                    </a>
                                    <form method="post" action="@Url.Action("Delete", "Personal", new { id = item.id_personal })" class="inline" onsubmit="return confirm('¿Estás seguro de eliminar este administrativo?');">
                                        <button type="submit" class="p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Eliminar">
                                            <i data-lucide="trash-2" class="h-4 w-4"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="px-6 py-12 text-center text-gray-500">
                            <div class="flex flex-col items-center justify-center">
                                <div class="bg-gray-50 p-3 rounded-full mb-3">
                                    <i data-lucide="users" class="h-6 w-6 text-gray-400"></i>
                                </div>
                                <p class="text-sm font-medium">No hay personal registrado</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
