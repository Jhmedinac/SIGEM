@model SIGCAP_TSC.Models.Personal.PersonalViewModel
@{
    ViewData["Title"] = (Model.id_personal.HasValue && Model.id_personal > 0) ? "Editar Personal" : "Nuevo Personal";
}

<div class="max-w-3xl mx-auto">
    <div class="mb-6 flex items-center gap-4">
        <a href="@Url.Action("Index", "Personal")" class="p-2 rounded-xl border border-gray-200 text-gray-500 hover:bg-gray-50 transition-colors">
            <i data-lucide="arrow-left" class="h-5 w-5"></i>
        </a>
        <div>
            <h2 class="text-xl font-bold text-gray-900">@ViewData["Title"]</h2>
            <p class="text-sm text-gray-500 mt-1">Completa la información del empleado o administrativo.</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ViewBag.Error))
    {
        <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-100 flex gap-3 text-red-800">
            <i data-lucide="alert-circle" class="h-5 w-5 shrink-0"></i>
            <p class="text-sm">@ViewBag.Error</p>
        </div>
    }

    <form method="post" action="@Url.Action("Save", "Personal")" class="bg-white rounded-2xl shadow-sm ring-1 ring-gray-900/5 p-6 lg:p-8">
        <input type="hidden" asp-for="id_personal" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Identificación -->
            <div class="md:col-span-2">
                <label asp-for="identificacion" class="block text-sm font-semibold text-gray-900 mb-2">Identificación *</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i data-lucide="credit-card" class="h-5 w-5 text-gray-400"></i>
                    </div>
                    <input asp-for="identificacion" class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 outline-none transition-all text-sm" placeholder="Ej: 0912345678" required maxlength="20" />
                </div>
            </div>

            <!-- Nombres -->
            <div>
                <label asp-for="nombres" class="block text-sm font-semibold text-gray-900 mb-2">Nombres *</label>
                <input asp-for="nombres" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 outline-none transition-all text-sm" placeholder="Nombres completos" required maxlength="100" />
            </div>

            <!-- Apellidos -->
            <div>
                <label asp-for="apellidos" class="block text-sm font-semibold text-gray-900 mb-2">Apellidos *</label>
                <input asp-for="apellidos" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 outline-none transition-all text-sm" placeholder="Apellidos completos" required maxlength="100" />
            </div>

            <!-- Email -->
            <div>
                <label asp-for="email" class="block text-sm font-semibold text-gray-900 mb-2">Correo Electrónico</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i data-lucide="mail" class="h-5 w-5 text-gray-400"></i>
                    </div>
                    <input asp-for="email" type="email" class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 outline-none transition-all text-sm" placeholder="correo@empresa.com" maxlength="150" />
                </div>
            </div>

            <!-- Teléfono -->
            <div>
                <label asp-for="telefono" class="block text-sm font-semibold text-gray-900 mb-2">Teléfono</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i data-lucide="phone" class="h-5 w-5 text-gray-400"></i>
                    </div>
                    <input asp-for="telefono" class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 outline-none transition-all text-sm" placeholder="Ej: 0991234567" maxlength="50" />
                </div>
            </div>

        </div>

        <div class="mt-8 pt-6 border-t border-gray-100 flex items-center justify-end gap-3">
            <a href="@Url.Action("Index", "Personal")" class="px-5 py-2.5 rounded-xl text-sm font-semibold text-gray-700 hover:bg-gray-100 transition-colors">
                Cancelar
            </a>
            <button type="submit" class="px-5 py-2.5 rounded-xl text-sm font-semibold bg-indigo-600 text-white hover:bg-indigo-700 shadow-sm shadow-indigo-200 transition-all flex items-center gap-2">
                <i data-lucide="save" class="h-4 w-4"></i>
                Guardar Personal
            </button>
        </div>
    </form>
</div>
