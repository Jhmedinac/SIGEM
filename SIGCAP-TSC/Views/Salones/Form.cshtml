@model SIGCAP_TSC.Models.Salones.SalonViewModel
@{
    ViewData["Title"] = Model.id_salon.HasValue ? "Editar Salón" : "Nuevo Salón";
}

<div class="max-w-3xl mx-auto mt-6">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-100 bg-white">
            <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
                @if (Model.id_salon.HasValue)
                {
                    <i data-lucide="edit" class="text-indigo-600 h-5 w-5"></i><span>Editar Salón</span>
                }
                else
                {
                    <i data-lucide="plus" class="text-indigo-600 h-5 w-5"></i><span>Registrar Salón</span>
                }
            </h2>
            <a href="@Url.Action("Index")" class="text-gray-400 hover:text-gray-600 p-1.5 rounded-full hover:bg-gray-100 transition">
                <i data-lucide="x" class="h-5 w-5"></i>
            </a>
        </div>

        <form asp-action="Save" method="post" class="p-6 space-y-5">
            <input type="hidden" asp-for="id_salon" />
            
            @if (ViewBag.Error != null)
            {
                <div class="flex items-center gap-2 bg-red-50 text-red-700 text-sm px-4 py-3 rounded-lg border border-red-200">
                    <i data-lucide="alert-circle" class="h-4 w-4 flex-shrink-0"></i> @ViewBag.Error
                </div>
            }

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <!-- Nombre de Salón -->
                <div class="md:col-span-2">
                    <label asp-for="nombre_salon" class="block text-sm font-medium text-gray-700 mb-1">Nombre del Salón *</label>
                    <input asp-for="nombre_salon" required maxlength="100" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:ring-indigo-500 focus:border-indigo-500" placeholder="Ej: Auditorio Principal, Sala B, Meets Virtual" />
                </div>

                <!-- Capacidad -->
                <div>
                    <label asp-for="capacidad" class="block text-sm font-medium text-gray-700 mb-1">Capacidad Máxima *</label>
                    <div class="mt-1 relative rounded-md shadow-sm">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i data-lucide="users" class="h-4 w-4 text-gray-400"></i>
                        </div>
                        <input asp-for="capacidad" type="number" min="1" required class="block w-full pl-10 rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="100" />
                    </div>
                </div>

                <!-- Ubicación -->
                <div class="md:col-span-2">
                    <label asp-for="ubicacion" class="block text-sm font-medium text-gray-700 mb-1">Ubicación Física o Enlace (Virtual)</label>
                    <textarea asp-for="ubicacion" rows="2" maxlength="255" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:ring-indigo-500 focus:border-indigo-500" placeholder="Ej: Av. Las Américas piso 4 / URL de Teams"></textarea>
                </div>
            </div>

            <!-- Estado Activo -->
            <div class="pt-4 mt-2 border-t border-gray-100">
                <label class="flex items-center gap-3 cursor-pointer">
                    <input asp-for="activo" type="checkbox" class="w-5 h-5 text-indigo-600 bg-gray-100 border-gray-300 rounded focus:ring-indigo-500 focus:ring-2 cursor-pointer" />
                    <span class="text-sm font-medium text-gray-700">El salón está activo y disponible para agendamientos</span>
                </label>
            </div>

            <!-- Actions -->
            <div class="flex justify-end gap-3 pt-6">
                <a href="@Url.Action("Index")" class="px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition">
                    Cancelar
                </a>
                <button type="submit" class="px-5 py-2.5 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition shadow-sm flex items-center gap-2">
                    <i data-lucide="save" class="h-4 w-4"></i> @(Model.id_salon.HasValue ? "Actualizar Salón" : "Registrar Salón")
                </button>
            </div>
        </form>
    </div>
</div>
