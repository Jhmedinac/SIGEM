@model List<SIGCAP_TSC.Models.Alertas.AlertaViewModel>
@{
    ViewData["Title"] = "Centro de Alertas";
    var counts = ViewBag.Counts as SIGCAP_TSC.Models.Alertas.AlertaCount;
}

<div class="max-w-7xl mx-auto space-y-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
            <p class="text-sm text-gray-500 mt-1">Monitoreo en tiempo real de situaciones que requieren atención.</p>
        </div>
        <button onclick="window.location.reload();" class="flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition shadow-sm text-sm font-medium">
            <i data-lucide="refresh-cw" class="h-4 w-4"></i>
            Actualizar
        </button>
    </div>

    <!-- KPI Cards -->
    @if (counts != null)
    {
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div class="rounded-2xl p-4 ring-1 shadow-sm bg-indigo-50 text-indigo-700 ring-indigo-200">
                <p class="text-xs font-semibold uppercase tracking-wide opacity-70">Total</p>
                <p class="text-3xl font-bold mt-1">@counts.total</p>
            </div>
            <div class="rounded-2xl p-4 ring-1 shadow-sm bg-red-50 text-red-700 ring-red-200">
                <p class="text-xs font-semibold uppercase tracking-wide opacity-70">Críticas</p>
                <p class="text-3xl font-bold mt-1">@counts.critical</p>
            </div>
            <div class="rounded-2xl p-4 ring-1 shadow-sm bg-amber-50 text-amber-700 ring-amber-200">
                <p class="text-xs font-semibold uppercase tracking-wide opacity-70">Atención</p>
                <p class="text-3xl font-bold mt-1">@counts.warning</p>
            </div>
            <div class="rounded-2xl p-4 ring-1 shadow-sm bg-indigo-50 text-indigo-600 ring-indigo-200">
                <p class="text-xs font-semibold uppercase tracking-wide opacity-70">Informativas</p>
                <p class="text-3xl font-bold mt-1">@counts.info</p>
            </div>
        </div>
    }

    <!-- Content -->
    @if (Model == null || !Model.Any())
    {
        <div class="flex flex-col items-center justify-center py-20 text-center bg-white rounded-2xl shadow-sm ring-1 ring-gray-900/5 mt-6">
            <div class="bg-emerald-50 p-5 rounded-full mb-4">
                <i data-lucide="check-circle" class="h-12 w-12 text-emerald-400"></i>
            </div>
            <h3 class="text-lg font-bold text-gray-900">¡Todo en orden!</h3>
            <p class="text-gray-400 text-sm mt-1 max-w-xs">
                No hay alertas activas en el sistema en este momento.
            </p>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var alerta in Model)
            {
                var iconName = "info";
                var colorText = "text-blue-600";
                var colorBg = "bg-blue-50";
                var colorBorder = "border-blue-200";
                var levelLabel = "Info";
                var levelClass = "bg-indigo-100 text-indigo-700";
                var levelIcon = "info";

                // Mapping types to config based on react equivalent
                switch (alerta.tipo)
                {
                    case "CUPO":
                    case "USUARIOS_BLOQUEADOS":
                    case "SIN_INSCRITOS":
                        iconName = "users"; break;
                    case "FACILITADOR":
                        iconName = "user-cog"; break;
                    case "SALON":
                        iconName = "door-open"; break;
                    case "INICIO_PROXIMO":
                        iconName = "calendar"; break;
                    case "FIN_PROXIMO":
                        iconName = "clock"; break;
                }

                // Level overrides
                switch (alerta.nivel)
                {
                    case "critical":
                        colorText = "text-red-600"; colorBg = "bg-red-50"; colorBorder = "border-red-200";
                        levelLabel = "Crítico"; levelClass = "bg-red-100 text-red-700"; levelIcon = "alert-circle";
                        break;
                    case "warning":
                        colorText = "text-amber-600"; colorBg = "bg-amber-50"; colorBorder = "border-amber-200";
                        levelLabel = "Atención"; levelClass = "bg-amber-100 text-amber-700"; levelIcon = "alert-triangle";
                        break;
                    case "info":
                        colorText = "text-indigo-600"; colorBg = "bg-indigo-50"; colorBorder = "border-indigo-200";
                        levelLabel = "Info"; levelClass = "bg-indigo-100 text-indigo-700"; levelIcon = "info";
                        break;
                }

                <div class="rounded-xl border shadow-sm overflow-hidden transition-all @colorBg @colorBorder">
                    <div class="flex items-start gap-4 p-4">
                        <div class="p-2.5 rounded-xl shrink-0 bg-white shadow-sm @colorText">
                            <i data-lucide="@iconName" class="h-5 w-5"></i>
                        </div>

                        <div class="flex-1 min-w-0">
                            <div class="flex flex-wrap items-center gap-2 mb-1">
                                <i data-lucide="@levelIcon" class="h-4 w-4 @(alerta.nivel == "critical" ? "text-red-500" : (alerta.nivel == "warning" ? "text-amber-500" : "text-indigo-400")) shrink-0"></i>
                                <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full @levelClass">@levelLabel</span>
                                <span class="text-[10px] font-semibold uppercase tracking-wider text-gray-400">@alerta.tipo.Replace("_", " ")</span>
                                
                                @if (!string.IsNullOrEmpty(alerta.codigo))
                                {
                                    <span class="font-mono text-[10px] bg-white px-2 py-0.5 rounded text-gray-500 border border-gray-200">@alerta.codigo</span>
                                }
                            </div>

                            <h3 class="font-bold text-sm @colorText">@alerta.titulo</h3>
                            <p class="text-gray-600 text-sm mt-0.5 break-words">@alerta.descripcion</p>

                            @if (alerta.meta != null)
                            {
                                @if (alerta.meta.fecha_inicio.HasValue)
                                {
                                    <p class="text-xs text-gray-400 mt-1 flex items-center gap-1">
                                        <i data-lucide="calendar" class="h-3 w-3"></i>
                                        Inicio: @alerta.meta.fecha_inicio.Value.ToString("dd MMMM yyyy")
                                    </p>
                                }
                                @if (alerta.meta.fecha_fin.HasValue && !alerta.meta.fecha_inicio.HasValue)
                                {
                                    <p class="text-xs text-gray-400 mt-1 flex items-center gap-1">
                                        <i data-lucide="clock" class="h-3 w-3"></i>
                                        Fin: @alerta.meta.fecha_fin.Value.ToString("dd MMMM yyyy")
                                    </p>
                                }
                                @if (alerta.meta.pct.HasValue)
                                {
                                    var pctValue = Math.Min(alerta.meta.pct.Value, 100);
                                    var barColor = pctValue >= 100 ? "bg-red-500" : (pctValue >= 90 ? "bg-amber-500" : "bg-emerald-500");
                                    
                                    <div class="mt-2 w-48">
                                        <div class="flex justify-between text-xs text-gray-500 mb-1">
                                            <span>Ocupación</span>
                                            <span class="font-bold">@alerta.meta.pct%</span>
                                        </div>
                                        <div class="h-1.5 bg-white rounded-full overflow-hidden border border-gray-200">
                                            <div class="h-full rounded-full transition-all @barColor" style="width: @pctValue.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                        </div>
                                    </div>
                                }

                                @if (alerta.meta.usuarios != null && alerta.meta.usuarios.Any())
                                {
                                    <div class="mt-3 border-t border-white/60 pt-3">
                                        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Usuarios Afectados</p>
                                        <div class="flex flex-wrap gap-2">
                                            @foreach (var u in alerta.meta.usuarios)
                                            {
                                                <div class="flex items-center gap-2 bg-white rounded-lg px-3 py-1.5 border border-amber-200 shadow-sm">
                                                    <div class="h-6 w-6 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center text-xs font-bold">
                                                        @(string.IsNullOrEmpty(u.nombre_completo) ? "?" : u.nombre_completo.Substring(0, 1))
                                                    </div>
                                                    <div>
                                                        <p class="text-xs font-semibold text-gray-800">@u.nombre_completo</p>
                                                        <p class="text-[10px] text-gray-400 font-mono">@@@u.username</p>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
