@{
    ViewData["Title"] = "Restablecer Contraseña";
}

<div class="flex min-h-screen items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-md space-y-8 rounded-xl bg-white p-10 shadow-lg border border-gray-100">
        <div>
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-green-100">
                <i data-lucide="shield-check" class="h-8 w-8 text-green-600"></i>
            </div>
            <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
                Crea una nueva contraseña
            </h2>
            <p class="mt-2 text-center text-sm text-gray-600">
                Por favor ingresa una contraseña segura y fácil de recordar.
            </p>
        </div>

        @if (ViewBag.Success != null)
        {
            <div class="rounded-md bg-green-50 p-5 border border-green-200">
                <div class="flex flex-col items-center text-center">
                    <i data-lucide="check-circle" class="h-10 w-10 text-green-500 mb-3"></i>
                    <h3 class="text-sm font-medium text-green-800">
                        @ViewBag.Success
                    </h3>
                </div>
            </div>
            <div class="mt-6">
                <a href="@Url.Action("Login", "Auth")" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700">
                    Ir a Iniciar Sesión
                </a>
            </div>
        }
        else
        {
            @if (ViewBag.Error != null)
            {
                <div class="rounded-md bg-red-50 p-4 border border-red-200 mb-6">
                    <div class="flex items-center">
                        <i data-lucide="alert-circle" class="h-5 w-5 text-red-500 mr-2"></i>
                        <span class="text-sm text-red-700">@ViewBag.Error</span>
                    </div>
                </div>
            }

            <form class="mt-8 space-y-6" action="@Url.Action("ResetPassword", "Auth")" method="POST">
                
                <input type="hidden" name="token" value="@ViewBag.Token" />

                <div class="space-y-4">
                    <div>
                        <label for="newPassword" class="block text-sm font-medium text-gray-700 mb-1">Nueva Contraseña</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i data-lucide="lock" class="h-5 w-5 text-gray-400"></i>
                            </div>
                            <input id="newPassword" name="newPassword" type="password" required class="appearance-none rounded-lg relative block w-full px-3 py-2.5 pl-10 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="Min. 8 caracteres">
                        </div>
                    </div>

                    <div>
                        <label for="confirmPassword" class="block text-sm font-medium text-gray-700 mb-1">Confirmar Contraseña</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i data-lucide="lock" class="h-5 w-5 text-gray-400"></i>
                            </div>
                            <input id="confirmPassword" name="confirmPassword" type="password" required class="appearance-none rounded-lg relative block w-full px-3 py-2.5 pl-10 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="Escríbela de nuevo">
                        </div>
                    </div>
                </div>

                <div>
                    <button type="submit" class="w-full flex justify-center py-2.5 px-4 border border-transparent text-sm font-medium rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 shadow-md transition-all">
                        Actualizar contraseña
                    </button>
                </div>
            </form>
        }
    </div>
</div>
