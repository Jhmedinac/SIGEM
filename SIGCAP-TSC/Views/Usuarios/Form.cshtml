@model SIGCAP_TSC.Models.Usuarios.UsuarioViewModel
@{
    ViewData["Title"] = (Model.id_usuario.HasValue && Model.id_usuario > 0) ? "Editar Usuario" : "Nuevo Usuario";
    var personasDisponibles = ViewBag.PersonasDisponibles as List<SIGCAP_TSC.Models.Usuarios.PersonaDisponibleViewModel>;
}

<div class="max-w-xl mx-auto">
    <div class="mb-6 flex items-center gap-4">
        <a href="@Url.Action("Index", "Usuarios")" class="p-2 rounded-xl border border-gray-200 text-gray-500 hover:bg-gray-50 transition-colors">
            <i data-lucide="arrow-left" class="h-5 w-5"></i>
        </a>
        <div>
            <h2 class="text-xl font-bold text-gray-900">@ViewData["Title"]</h2>
            <p class="text-sm text-gray-500 mt-1">Configura las credenciales de acceso al sistema.</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ViewBag.Error))
    {
        <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-100 flex gap-3 text-red-800">
            <i data-lucide="alert-circle" class="h-5 w-5 shrink-0"></i>
            <p class="text-sm">@ViewBag.Error</p>
        </div>
    }

    <form method="post" action="@Url.Action("Save", "Usuarios")" class="bg-white rounded-2xl shadow-sm ring-1 ring-gray-900/5 p-6 lg:p-8">
        <input type="hidden" asp-for="id_usuario" />

        <div class="space-y-6">
            @if (!Model.id_usuario.HasValue || Model.id_usuario == 0)
            {
                <!-- Asignar Persona (Solo creación) -->
                <div>
                    <label asp-for="id_persona" class="block text-sm font-semibold text-gray-900 mb-2">Asociar a Persona</label>
                    <select asp-for="id_persona" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 outline-none transition-all text-sm" required>
                        <option value="">-- Seleccione una persona sin acceso --</option>
                        @if (personasDisponibles != null)
                        {
                            foreach (var p in personasDisponibles)
                            {
                                <option value="@p.id_persona">@p.nombres @p.apellidos (@p.identificacion)</option>
                            }
                        }
                    </select>
                    <p class="text-xs text-gray-500 mt-2">Solo aparecen las personas que actualmente no tienen una cuenta de usuario.</p>
                </div>
            }
            else
            {
                <input type="hidden" asp-for="id_persona" />
            }

            <!-- Username -->
            <div>
                <label asp-for="username" class="block text-sm font-semibold text-gray-900 mb-2">Nombre de Usuario</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i data-lucide="user" class="h-5 w-5 text-gray-400"></i>
                    </div>
                    <input asp-for="username" class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 outline-none transition-all text-sm" placeholder="ej. jmoreno" required maxlength="50" autocomplete="username" />
                </div>
            </div>

            @if (!Model.id_usuario.HasValue || Model.id_usuario == 0)
            {
                <!-- Contraseña (Solo creación) -->
                <div>
                    <label asp-for="password" class="block text-sm font-semibold text-gray-900 mb-2">Contraseña Temporal</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i data-lucide="key" class="h-5 w-5 text-gray-400"></i>
                        </div>
                        <input asp-for="password" type="password" class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 outline-none transition-all text-sm" required minlength="6" autocomplete="new-password" />
                    </div>
                </div>
            }

            <!-- Estado de Bloqueo -->
            @if (Model.id_usuario.HasValue && Model.id_usuario > 0)
            {
                <div class="flex items-center mt-2 p-4 border border-gray-100 rounded-xl bg-gray-50">
                    <div class="flex items-center h-5">
                        <input asp-for="is_locked" type="checkbox" class="h-4 w-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-600" />
                    </div>
                    <div class="ml-3 text-sm">
                        <label asp-for="is_locked" class="font-semibold text-gray-900">Bloquear Usuario</label>
                        <p class="text-gray-500 text-xs">Si está bloqueado, el usuario no podrá acceder al sistema independiente de sus credenciales.</p>
                    </div>
                </div>
            }
        </div>

        <div class="mt-8 pt-6 border-t border-gray-100 flex items-center justify-end gap-3">
            <a href="@Url.Action("Index", "Usuarios")" class="px-5 py-2.5 rounded-xl text-sm font-semibold text-gray-700 hover:bg-gray-100 transition-colors">
                Cancelar
            </a>
            <button type="submit" class="px-5 py-2.5 rounded-xl text-sm font-semibold bg-indigo-600 text-white hover:bg-indigo-700 shadow-sm shadow-indigo-200 transition-all flex items-center gap-2">
                <i data-lucide="save" class="h-4 w-4"></i>
                @((Model.id_usuario.HasValue && Model.id_usuario > 0) ? "Actualizar Usuario" : "Crear Usuario")
            </button>
        </div>
    </form>
</div>
