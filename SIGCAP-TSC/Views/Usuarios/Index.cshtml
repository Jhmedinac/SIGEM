@model List<SIGCAP_TSC.Models.Usuarios.UsuarioViewModel>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
        <p class="text-sm text-gray-500 mt-1">Administra los accesos y credenciales de los usuarios</p>
    </div>
    <a href="@Url.Action("Form", "Usuarios")" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl text-sm font-semibold transition-all shadow-sm shadow-indigo-200">
        <i data-lucide="shield-check" class="h-4 w-4"></i>
        Nuevo Usuario
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="mb-6 p-4 rounded-xl bg-green-50 border border-green-100 flex gap-3 text-green-800">
        <i data-lucide="check-circle" class="h-5 w-5 shrink-0"></i>
        <p class="text-sm">@TempData["Success"]</p>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-100 flex gap-3 text-red-800">
        <i data-lucide="alert-circle" class="h-5 w-5 shrink-0"></i>
        <p class="text-sm">@TempData["Error"]</p>
    </div>
}

<div class="bg-white rounded-2xl shadow-sm ring-1 ring-gray-900/5 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100">
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Usuario</th>
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Persona Asociada</th>
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Estado</th>
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-right">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors group">
                            <td class="px-6 py-4">
                                <span class="text-sm font-semibold text-gray-900">@item.username</span>
                            </td>
                            <td class="px-6 py-4">
                                <p class="text-sm text-gray-600">@item.PersonaNombre</p>
                            </td>
                            <td class="px-6 py-4 text-sm">
                                @if (item.is_locked)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-50 text-red-700">
                                        <i data-lucide="lock" class="h-3.5 w-3.5"></i> Bloqueado
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-50 text-green-700">
                                        <i data-lucide="unlock" class="h-3.5 w-3.5"></i> Activo
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <form method="post" action="@Url.Action("ToggleLock", "Usuarios", new { id = item.id_usuario, isLocked = !item.is_locked })" class="inline">
                                        <button type="submit" class="p-2 text-gray-400 hover:text-amber-600 hover:bg-amber-50 rounded-lg transition-colors" title="@(item.is_locked ? "Desbloquear" : "Bloquear")">
                                            @if (item.is_locked)
                                            {
                                                <i data-lucide="unlock" class="h-4 w-4"></i>
                                            }
                                            else
                                            {
                                                <i data-lucide="lock" class="h-4 w-4"></i>
                                            }
                                        </button>
                                    </form>
                                    <a href="@Url.Action("Form", "Usuarios", new { id = item.id_usuario })" class="p-2 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors" title="Editar">
                                        <i data-lucide="edit-2" class="h-4 w-4"></i>
                                    </a>
                                     <button type="button" onclick="document.getElementById('reset-modal-@item.id_usuario').classList.remove('hidden')" class="p-2 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="Restablecer Contraseña">
                                        <i data-lucide="key" class="h-4 w-4"></i>
                                    </button>
                                    <form method="post" action="@Url.Action("Delete", "Usuarios", new { id = item.id_usuario })" class="inline" onsubmit="return confirm('¿Estás seguro de eliminar este usuario de forma permanente?');">
                                        <button type="submit" class="p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Eliminar">
                                            <i data-lucide="trash-2" class="h-4 w-4"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>

                        <!-- Modal Reset Password -->
                        <div id="reset-modal-@item.id_usuario" class="fixed inset-0 z-50 hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
                            <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
                                <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true" onclick="document.getElementById('reset-modal-@item.id_usuario').classList.add('hidden')"></div>
                                <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
                                <div class="inline-block align-bottom bg-white rounded-xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
                                    <form method="post" action="@Url.Action("ResetPassword", "Usuarios", new { id = item.id_usuario })">
                                        <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                                            <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left">
                                                <h3 class="text-lg leading-6 font-semibold text-gray-900" id="modal-title">
                                                    Restablecer contraseña para @item.username
                                                </h3>
                                                <div class="mt-4">
                                                    <label class="block text-sm font-medium text-gray-700 mb-1">Nueva Contraseña</label>
                                                    <input type="password" name="newPassword" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-indigo-500" required minlength="6">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="bg-gray-50 px-4 py-3 sm:px-6 flex justify-end gap-3">
                                            <button type="button" class="btn bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 px-4 py-2 rounded-lg text-sm font-medium" onclick="document.getElementById('reset-modal-@item.id_usuario').classList.add('hidden')">Cancelar</button>
                                            <button type="submit" class="btn bg-indigo-600 text-white hover:bg-indigo-700 px-4 py-2 rounded-lg text-sm font-medium">Restablecer</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="px-6 py-12 text-center text-gray-500">
                            <div class="flex flex-col items-center justify-center">
                                <div class="bg-gray-50 p-3 rounded-full mb-3">
                                    <i data-lucide="shield-off" class="h-6 w-6 text-gray-400"></i>
                                </div>
                                <p class="text-sm font-medium">No hay usuarios registrados</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
