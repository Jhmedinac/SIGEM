<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SIGEM Dashboard</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <div class="bg-white border-end" id="sidebar-wrapper">
            <div class="sidebar-heading border-bottom bg-primary text-white text-center py-3 fs-4 fw-bold">SIGEM</div>
            <div class="list-group list-group-flush mt-3">
                <a href="#" class="list-group-item list-group-item-action list-group-item-light p-3 active"><i class="bi bi-grid me-2"></i> Dashboard</a>
                <a href="#" class="list-group-item list-group-item-action list-group-item-light p-3"><i class="bi bi-mortarboard me-2"></i> Capacitaciones</a>
                <a href="#" class="list-group-item list-group-item-action list-group-item-light p-3"><i class="bi bi-person-plus me-2"></i> Inscripciones</a>
                <a href="#" class="list-group-item list-group-item-action list-group-item-light p-3"><i class="bi bi-archive me-2"></i> Archivado</a>
                <a href="#" class="list-group-item list-group-item-action list-group-item-light p-3"><i class="bi bi-building me-2"></i> Salones</a>
                <a href="#" class="list-group-item list-group-item-action list-group-item-light p-3"><i class="bi bi-people me-2"></i> Participantes</a>
                <a href="#" class="list-group-item list-group-item-action list-group-item-light p-3"><i class="bi bi-person-badge me-2"></i> Facilitadores</a>
                <a href="#" class="list-group-item list-group-item-action list-group-item-light p-3"><i class="bi bi-shield-lock me-2"></i> Usuarios</a>
                <a href="#" class="list-group-item list-group-item-action list-group-item-light p-3"><i class="bi bi-bell me-2"></i> Alertas</a>
                <a href="#" class="list-group-item list-group-item-action list-group-item-light p-3"><i class="bi bi-gear me-2"></i> Configuraciones</a>
                
                <div class="mt-auto border-top p-3">
                     <a class="nav-link text-danger fw-bold" asp-controller="Auth" asp-action="Logout">
                        <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
                     </a>
                </div>
            </div>
        </div>
        
        <!-- Page Content -->
        <div id="page-content-wrapper" class="w-100 bg-light">
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom px-4 py-3">
                <div class="d-flex align-items-center justify-content-between w-100">
                    <h3 class="m-0 fw-bold text-dark">Dashboard</h3>
                    
                    <div class="d-flex align-items-center gap-3">
                        <div class="text-secondary small">
                            <i class="bi bi-calendar3 me-1"></i> @DateTime.Now.ToString("dd/MM/yyyy")
                        </div>
                         <div class="dropdown">
                            <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px;">A</div>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end text-small shadow" aria-labelledby="dropdownUser1">
                                <li><a class="dropdown-item" href="#">Perfil</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="Auth" asp-action="Logout">Sign out</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <div class="container-fluid px-4 py-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
