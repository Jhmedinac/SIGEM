@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
@model ApiClient.Models.Dashboard.DashboardStatsViewModel

<div class="mb-4">
    <h2 class="fw-bold text-dark">Bienvenido de nuevo, Admin</h2>
    <p class="text-secondary">Aquí tienes el resumen de hoy.</p>
</div>

<!-- Stats Rows -->
<div class="row g-4 mb-4">
    <!-- Card 1 -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card card-stats h-100 p-3">
            <div class="d-flex align-items-center">
                <div class="icon-box bg-primary bg-opacity-10 text-primary me-3">
                    <i class="bi bi-calendar-event"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 small uppercase">Eventos Activos</h6>
                    <h3 class="mb-0 fw-bold">@Model.ActiveEventsCount</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 2 -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card card-stats h-100 p-3">
            <div class="d-flex align-items-center">
                <div class="icon-box bg-success bg-opacity-10 text-success me-3">
                    <i class="bi bi-person-check"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 small uppercase">En Capacitación</h6>
                    <h3 class="mb-0 fw-bold">@Model.UsersInTrainingCount</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 3 -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card card-stats h-100 p-3">
            <div class="d-flex align-items-center">
                <div class="icon-box bg-info bg-opacity-10 text-info me-3">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 small uppercase">Total Usuarios</h6>
                    <h3 class="mb-0 fw-bold">@Model.TotalUsers</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 4 -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card card-stats h-100 p-3">
            <div class="d-flex align-items-center">
                <div class="icon-box bg-warning bg-opacity-10 text-warning me-3">
                    <i class="bi bi-building"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 small uppercase">Salones Activos</h6>
                    <h3 class="mb-0 fw-bold">@Model.ActiveSalones</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts & Lists Row -->
<div class="row g-4">
    <!-- Chart Column -->
    <div class="col-12 col-lg-8">
        <div class="card card-chart h-100 p-4">
            <h5 class="fw-bold mb-4">Estados</h5>
            <canvas id="estadosChart" height="120"></canvas>
        </div>
    </div>

    <!-- List Column -->
    <div class="col-12 col-lg-4">
        <div class="card card-chart h-100 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold m-0">Próximos Eventos</h5>
                <a href="#" class="small text-decoration-none">Ver calendario</a>
            </div>
            
            <div class="table-responsive">
                <table class="table table-borderless align-middle mb-0">
                    <thead class="text-secondary small text-uppercase">
                        <tr>
                            <th>Evento</th>
                            <th>Fecha</th>
                            <th>Cupo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.UpcomingEvents != null && Model.UpcomingEvents.Any())
                        {
                            @foreach (var evento in Model.UpcomingEvents)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary bg-opacity-10 text-primary rounded p-1 me-2">
                                                <i class="bi bi-calendar-event"></i>
                                            </div>
                                            <div class="d-flex flex-column">
                                                <span class="fw-bold small text-truncate" style="max-width: 150px;">@evento.nombre_evento</span>
                                                <span class="text-muted" style="font-size: 0.75rem;">@evento.estado</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="small">
                                        @* Parse date if string or display directly *@
                                        @{
                                            DateTime fecha;
                                            bool isDate = DateTime.TryParse(evento.fecha_inicio, out fecha);
                                        }
                                        <span class="fw-semibold">@(isDate ? fecha.ToString("dd/MM") : evento.fecha_inicio)</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center small">
                                            <div class="progress flex-grow-1 me-2" style="height: 6px; width: 50px;">
                                                @{
                                                    var porcentaje = evento.cupo_maximo > 0 ? (double)evento.cupo_actual / evento.cupo_maximo * 100 : 0;
                                                    var colorClass = porcentaje > 90 ? "bg-danger" : (porcentaje > 70 ? "bg-warning" : "bg-success");
                                                }
                                                <div class="progress-bar @colorClass" role="progressbar" style="width: @porcentaje%"></div>
                                            </div>
                                            <span class="text-muted">@evento.cupo_actual/@evento.cupo_maximo</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">
                                    No hay eventos próximos agendados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var ctx = document.getElementById('estadosChart').getContext('2d');
            var myChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['null', 'ADMIN', 'USER'],
                    datasets: [{
                        label: 'Usuarios',
                        // Injecting data from model might be tricky directly if we want dynamic grouping. 
                        // For now we will keep static or partial dynamic if we pass data from View to JS via a global var.
                        // Let's make it consistent for now with stats, but ideally we should fetch chart data or pass it.
                        // Given user asked for "datos de tabla", I prioritized the list.
                        // Let's assume chart is still static or we can inject:
                        data: [@Model.TotalUsers, 2, 5], 
                        backgroundColor: [
                            'rgba(88, 86, 214, 0.8)', // Primary Purple-ish
                            'rgba(75, 192, 192, 0.8)',
                            'rgba(255, 205, 86, 0.8)'
                        ],
                        borderRadius: 4,
                        barThickness: 20
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                borderDash: [2, 4],
                                drawBorder: false
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        }
                    }
                }
            });
        });
    </script>
}
