@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
@model ApiClient.Models.Dashboard.DashboardStatsViewModel

<div class="mb-4">
    <h2 class="fw-bold text-dark">Bienvenido de nuevo, Admin</h2>
    <p class="text-secondary">Aquí tienes el resumen de hoy.</p>
</div>

<!-- Stats Rows -->
<div class="row g-4 mb-4">
    <!-- Card 1 -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card card-stats h-100 p-3">
            <div class="d-flex align-items-center">
                <div class="icon-box bg-primary bg-opacity-10 text-primary me-3">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 small uppercase">Usuarios Totales</h6>
                    <h3 class="mb-0 fw-bold">@Model.TotalUsers</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 2 -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card card-stats h-100 p-3">
            <div class="d-flex align-items-center">
                <div class="icon-box bg-success bg-opacity-10 text-success me-3">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 small uppercase">Activos</h6>
                    <h3 class="mb-0 fw-bold">@Model.ActiveUsers</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 3 -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card card-stats h-100 p-3">
            <div class="d-flex align-items-center">
                <div class="icon-box bg-danger bg-opacity-10 text-danger me-3">
                    <i class="bi bi-x-circle"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 small uppercase">Inactivos</h6>
                    <h3 class="mb-0 fw-bold">@Model.InactiveUsers</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Card 4 -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="card card-stats h-100 p-3">
            <div class="d-flex align-items-center">
                <div class="icon-box bg-warning bg-opacity-10 text-warning me-3">
                    <i class="bi bi-building"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-1 small uppercase">Salones Activos</h6>
                    <h3 class="mb-0 fw-bold">@Model.ActiveSalones</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts & Lists Row -->
<div class="row g-4">
    <!-- Chart Column -->
    <div class="col-12 col-lg-8">
        <div class="card card-chart h-100 p-4">
            <h5 class="fw-bold mb-4">Estados</h5>
            <canvas id="estadosChart" height="120"></canvas>
        </div>
    </div>

    <!-- List Column -->
    <div class="col-12 col-lg-4">
        <div class="card card-chart h-100 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold m-0">Últimos Registros</h5>
                <span class="badge bg-light text-secondary">Hoy</span>
            </div>
            
            <div class="d-flex flex-column gap-3">
                @if (Model.LatestUsers != null)
                {
                    @foreach (var user in Model.LatestUsers)
                    {
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                        @(string.IsNullOrEmpty(user.NOMB_USUA) ? "?" : user.NOMB_USUA.Substring(0, 1))
                                    </div>
                                    <span class="small fw-semibold text-uppercase">@user.NOMB_USUA</span>
                            </div>
                            @if (user.BLOQUEADO == true)
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3">Inactivo</span>
                            }
                            else
                            {
                                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">Activo</span>
                            }
                        </div>
                    }
                }
            </div>
            
            <div class="mt-auto text-center pt-3">
                <a href="#" class="text-decoration-none small fw-bold">Ver todos los usuarios</a>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var ctx = document.getElementById('estadosChart').getContext('2d');
            var myChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['null', 'ADMIN', 'USER'],
                    datasets: [{
                        label: 'Usuarios',
                        // Injecting data from model might be tricky directly if we want dynamic grouping. 
                        // For now we will keep static or partial dynamic if we pass data from View to JS via a global var.
                        // Let's make it consistent for now with stats, but ideally we should fetch chart data or pass it.
                        // Given user asked for "datos de tabla", I prioritized the list.
                        // Let's assume chart is still static or we can inject:
                        data: [@Model.TotalUsers, 2, 5], 
                        backgroundColor: [
                            'rgba(88, 86, 214, 0.8)', // Primary Purple-ish
                            'rgba(75, 192, 192, 0.8)',
                            'rgba(255, 205, 86, 0.8)'
                        ],
                        borderRadius: 4,
                        barThickness: 20
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                borderDash: [2, 4],
                                drawBorder: false
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        }
                    }
                }
            });
        });
    </script>
}
